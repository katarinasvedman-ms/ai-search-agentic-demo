{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SecureRagChat": "Debug"
    }
  },
  "AllowedHosts": "*",

  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "5c483258-25ac-4a26-ab6e-0b557127bc81",
    "ClientId": "<YOUR_CLIENT_ID>",
    "Audience": "<YOUR_API_AUDIENCE>"
  },

  "AzureSearch": {
    "Endpoint": "https://<YOUR_SEARCH_SERVICE>.search.windows.net",
    "PublicIndex": "public-index",
    "EntitledIndex": "entitled-index",
    "ApiVersion": "2025-11-01-preview",
    "EnableSemanticRanking": true,
    "SemanticConfiguration": "default"
  },

  "AgenticRetrieval": {
    "Endpoint": "https://<YOUR_SEARCH_SERVICE>.search.windows.net",
    "KnowledgeBaseName": "<YOUR_KNOWLEDGE_BASE_NAME>",
    "ApiVersion": "2025-11-01-preview",
    "IncludeActivity": true,
    "MaxOutputSize": 6000,
    "MaxRuntimeInSeconds": 30
  },

  "AzureOpenAI": {
    "Endpoint": "https://<YOUR_OPENAI_RESOURCE>.openai.azure.com",
    "Model": "gpt-4.1"
  }
}
